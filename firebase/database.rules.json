{
  "rules": {
    ".read": false,
    ".write": false,

    "sensor": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('devices').child(auth.uid).val() === true",
      "temperature": { ".validate": "newData.isNumber()" },
      "humidity": { ".validate": "newData.isNumber()" },
      "timestamp": { ".validate": "newData.isNumber()" }
    },

    "status": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('devices').child(auth.uid).val() === true",
      "mist": { ".validate": "newData.isBoolean()" },
      "tank": { ".validate": "newData.isString()" },
      "pump": { ".validate": "newData.isBoolean()" },
      "esp1Online": { ".validate": "newData.isBoolean()" },
      "gateway": { ".validate": "newData.isString()" },
      "lastSeen": { ".validate": "newData.isNumber()" }
    },

    "config": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "hset": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
      "deadband": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50" },
      "lastUpdate": { ".validate": "newData.isString()" },
      "updatedBy": { ".validate": "newData.isString()" }
    },

    "admins": {
      ".read": false,
      ".write": false,
      "$uid": { ".read": "auth != null && auth.uid === $uid" }
    },

    "devices": {
      ".read": false,
      ".write": false,
      "$uid": { ".read": "auth != null && auth.uid === $uid" }
    }
  }
}
